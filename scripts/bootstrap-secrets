#!/bin/bash
set -eu -o pipefail

usage() {
  cat <<EOF
Usage: $(basename "$0") [OPTIONS]

Bootstrap secrets from 1Password into macOS Keychain.

OPTIONS:
  --apply     Apply changes (default is diff/dry-run mode)
  -h, --help  Show this help message
EOF
}

APPLY_MODE=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --apply) APPLY_MODE=true; shift ;;
    -h|--help) usage; exit 0 ;;
    *) echo "Unknown option: $1" >&2; usage >&2; exit 1 ;;
  esac
done

sync_secret() {
  local service="$1"
  local op_ref="$2"

  local op_value
  if ! op_value=$(op read "$op_ref" 2>/dev/null); then
    echo "❌ Failed to read $service from 1Password"
    exit 1
  fi

  local current_value
  current_value=$(/usr/bin/security find-generic-password -a "$(id -un)" -s "$service" -w 2>/dev/null || echo "")

  if [[ "$current_value" == "$op_value" ]]; then
    echo "✅ $service is up to date"
    return
  fi

  if [[ "$APPLY_MODE" == "true" ]]; then
    /usr/bin/security add-generic-password -U -a "$(id -un)" -s "$service" -w "$op_value"
    echo "✅ Updated $service in Keychain"
  else
    if [[ -z "$current_value" ]]; then
      echo "📝 Would add $service to Keychain"
    else
      echo "📝 Would update $service in Keychain"
    fi
  fi
}

if [[ "$APPLY_MODE" == "true" ]]; then
  echo "🚀 Applying secrets to Keychain..."
else
  echo "🔍 Diff mode: showing what would change"
fi

sync_secret "healthchecks-api-key" "op://infra/healthchecks/api-key"
sync_secret "healthchecks-ping-key" "op://infra/healthchecks/PING_KEY"

echo ""
if [[ "$APPLY_MODE" == "true" ]]; then
  echo "✅ Bootstrap complete!"
else
  echo "✅ Diff complete!"
  echo ""
  echo "📋 To apply changes, run:"
  echo "  ./scripts/bootstrap-secrets --apply"
fi
